  private resetBtn: HTMLElement;

  // Camera zoom controls
  private cameraZoomSlider?: HTMLInputElement;
  private cameraZoomValue?: HTMLElement;
  private getCameraZoom?: () => number;
  private setCameraZoom?: (v: number) => void;
  
  private debugVisualsCheckbox: HTMLInputElement;
  private consoleCheckbox: HTMLInputElement;
  private shadowsCheckbox?: HTMLInputElement;
  
  // Performance elements
  private perfFps: HTMLElement;
  private perfMeshes: HTMLElement;
  private perfPolys: HTMLElement;
  private perfMemory: HTMLElement;
  private perfCanvas: HTMLCanvasElement;
  private perfCtx: CanvasRenderingContext2D;
  
  // Console overlay elements
  private consoleOverlay: HTMLElement;
  private consoleTitle: HTMLElement;
  private consoleTabLogsBtn: HTMLButtonElement;
  private consoleTabProfilerBtn: HTMLButtonElement;
  private consoleLogsPanel: HTMLElement;
  private consoleProfilerPanel: HTMLElement;
  private consoleContent: HTMLElement;
  private consoleProfilerSummary: HTMLElement;
  private consoleProfilerTable: HTMLElement;
  private consoleClearBtn: HTMLElement;
  private consoleCloseBtn: HTMLElement;
  
  // Console messages
  private consoleMessages: { type: string; message: string; timestamp: Date }[] = [];
  private readonly maxConsoleMessages = 100;
  private activeConsoleTab: 'logs' | 'profiler' = 'logs';

  // Profiler samples
  private profilerSamples: { frameTime: number; phases: Record<string, number> }[] = [];
  private readonly maxProfilerSamples = 120;
  
  // Original console methods
  private originalLog!: (...args: any[]) => void;
  private originalWarn!: (...args: any[]) => void;
  private originalError!: (...args: any[]) => void;
  private originalDebug!: (...args: any[]) => void;

  // Default light params for reset
  private defaultLightParams: any = {};

  // Graph data
  private frameTimes: number[] = [];
  private physicsTimes: number[] = [];
  private renderTimes: number[] = [];
  private maxHistory = 100;
  
  private getLightParams: () => any;
  private setLightParams: (params: any) => void;
  private toggleDebugVisuals: () => void;
  private toggleParticles: (v: boolean) => void;
  private toggleSprites: (v: boolean) => void;
  private setShadowsEnabled?: (enabled: boolean) => void;
  
  constructor(
    getLightParams: () => any,
    setLightParams: (params: any) => void,
    toggleDebugVisuals: () => void,
    toggleParticles: (v: boolean) => void,
    toggleSprites: (v: boolean) => void,
    getCameraZoom?: () => number,
    setCameraZoom?: (v: number) => void,
    setShadowsEnabled?: (enabled: boolean) => void
  ) {
    this.getLightParams = getLightParams;
    this.setLightParams = setLightParams;
    this.toggleDebugVisuals = toggleDebugVisuals;
    this.toggleParticles = toggleParticles;
    this.toggleSprites = toggleSprites;
    this.getCameraZoom = getCameraZoom;
    this.setCameraZoom = setCameraZoom;
    this.setShadowsEnabled = setShadowsEnabled;
    
    this.panel = document.getElementById('debug-panel')!;
    this.perfPanel = document.getElementById('perf-panel')!;
    this.closeBtn = document.getElementById('debug-close')!;
    
    this.hemiIntensitySlider = document.getElementById('debug-hemi-intensity-slider') as HTMLInputElement;
    this.hemiIntensityValue = document.getElementById('debug-hemi-intensity')!;
    this.hemiColorPicker = document.getElementById('debug-hemi-color') as HTMLInputElement;
    this.hemiGroundColorPicker = document.getElementById('debug-hemi-ground-color') as HTMLInputElement;
    
    this.sunIntensitySlider = document.getElementById('debug-sun-intensity-slider') as HTMLInputElement;
    this.sunIntensityValue = document.getElementById('debug-sun-intensity')!;
    this.sunColorPicker = document.getElementById('debug-sun-color') as HTMLInputElement;
    
    this.exposureSlider = document.getElementById('debug-exposure-slider') as HTMLInputElement;
    this.exposureValue = document.getElementById('debug-exposure')!;

    this.envMapIntensitySlider = document.getElementById('debug-env-map-slider') as HTMLInputElement;
    this.envMapIntensityValue = document.getElementById('debug-env-map')!;

    this.fogColorPicker = document.getElementById('debug-fog-color') as HTMLInputElement;
    this.fogDensitySlider = document.getElementById('debug-fog-density-slider') as HTMLInputElement;
    this.fogDensityValue = document.getElementById('debug-fog-density')!;

    this.resetBtn = document.getElementById('debug-reset-btn')!;

    // Store default light params on init
    this.defaultLightParams = this.getLightParams();
    const zoomSliderEl = document.getElementById('debug-camera-zoom-slider');
    const zoomValueEl = document.getElementById('debug-camera-zoom-value');
    if (zoomSliderEl && zoomValueEl) {
      this.cameraZoomSlider = zoomSliderEl as HTMLInputElement;
      this.cameraZoomValue = zoomValueEl as HTMLElement;
    }
    
    this.debugVisualsCheckbox = document.getElementById('perf-visuals-checkbox') as HTMLInputElement;
    const particlesCheckbox = document.getElementById('perf-particles-checkbox') as HTMLInputElement;
    if (particlesCheckbox) {
      particlesCheckbox.addEventListener('change', () => {
        this.toggleParticles(particlesCheckbox.checked);
      });
    }

    const spritesCheckbox = document.getElementById('perf-sprites-checkbox') as HTMLInputElement;
    if (spritesCheckbox) {
      spritesCheckbox.addEventListener('change', () => {
        this.toggleSprites(spritesCheckbox.checked);
      });
    }
    
    // Performance initialization
    this.perfFps = document.getElementById('perf-fps')!;
    this.perfMeshes = document.getElementById('perf-meshes')!;
    this.perfPolys = document.getElementById('perf-polys')!;
    this.perfMemory = document.getElementById('perf-memory')!;
    this.perfCanvas = document.getElementById('perf-graph') as HTMLCanvasElement;
    this.perfCtx = this.perfCanvas.getContext('2d')!;
    
    // Resize canvas based on client width
    this.perfCanvas.width = this.perfCanvas.clientWidth;
    this.perfCanvas.height = this.perfCanvas.clientHeight;
    
    // Console overlay initialization
    this.consoleCheckbox = document.getElementById('perf-console-checkbox') as HTMLInputElement;
    this.consoleOverlay = document.getElementById('console-overlay')!;
    this.consoleTitle = document.getElementById('console-title')!;
    this.consoleTabLogsBtn = document.getElementById('console-tab-logs') as HTMLButtonElement;
    this.consoleTabProfilerBtn = document.getElementById('console-tab-profiler') as HTMLButtonElement;
    this.consoleLogsPanel = document.getElementById('console-logs-panel')!;
    this.consoleProfilerPanel = document.getElementById('console-profiler-panel')!;
    this.consoleContent = document.getElementById('console-content')!;
    this.consoleProfilerSummary = document.getElementById('console-profiler-summary')!;
    this.consoleProfilerTable = document.getElementById('console-profiler-table')!;
    this.consoleClearBtn = document.getElementById('console-clear')!;
    this.consoleCloseBtn = document.getElementById('console-close')!;

    // Optional shadows checkbox — sync initial state with ?noShadows URL parameter
    const shadowsCheckboxEl = document.getElementById('perf-shadows-checkbox');
    if (shadowsCheckboxEl) {
      this.shadowsCheckbox = shadowsCheckboxEl as HTMLInputElement;
      const noShadows = new URLSearchParams(window.location.search).get('noShadows') === 'true';
      if (noShadows) {
        this.shadowsCheckbox.checked = false;
      }
    }
    
    this.setupConsoleInterception();
    this.importEarlyConsoleMessages();
    this.setupEventListeners();
    this.setupKeyboardListener();
  }
  
  private setupEventListeners(): void {
    this.closeBtn.addEventListener('click', () => this.toggle(false));
    
    this.hemiIntensitySlider.addEventListener('input', () => {
      const value = parseFloat(this.hemiIntensitySlider.value);
      this.hemiIntensityValue.textContent = value.toFixed(1);
      this.setLightParams({ hemiIntensity: value });
    });
    
    this.hemiColorPicker.addEventListener('input', () => {
      const value = parseInt(this.hemiColorPicker.value.replace('#', ''), 16);
      this.setLightParams({ hemiSkyColor: value });
    });

    this.hemiGroundColorPicker.addEventListener('input', () => {
      const value = parseInt(this.hemiGroundColorPicker.value.replace('#', ''), 16);
      this.setLightParams({ hemiGroundColor: value });
    });
    
    this.sunIntensitySlider.addEventListener('input', () => {
      const value = parseFloat(this.sunIntensitySlider.value);
      this.sunIntensityValue.textContent = value.toFixed(2);
      this.setLightParams({ sunIntensity: value });
    });
    
    this.sunColorPicker.addEventListener('input', () => {
      const value = parseInt(this.sunColorPicker.value.replace('#', ''), 16);
      this.setLightParams({ sunColor: value });
    });
    
    this.exposureSlider.addEventListener('input', () => {
      const value = parseFloat(this.exposureSlider.value);
      this.exposureValue.textContent = value.toFixed(1);
      this.setLightParams({ exposure: value });
    });

    this.envMapIntensitySlider.addEventListener('input', () => {
      const value = parseFloat(this.envMapIntensitySlider.value);
      this.envMapIntensityValue.textContent = value.toFixed(1);
      this.setLightParams({ envMapIntensity: value });
    });

    this.fogColorPicker.addEventListener('input', () => {
      const value = parseInt(this.fogColorPicker.value.replace('#', ''), 16);
      this.setLightParams({ fogColor: value });
    });

    this.fogDensitySlider.addEventListener('input', () => {
      const value = parseFloat(this.fogDensitySlider.value);
      this.fogDensityValue.textContent = value.toFixed(3);
      this.setLightParams({ fogDensity: value });
    });

    this.resetBtn.addEventListener('click', () => {
      this.resetToDefaults();
    });
    if (this.cameraZoomSlider && this.cameraZoomValue && this.setCameraZoom) {
      this.cameraZoomSlider.addEventListener('input', () => {
        const v = parseFloat(this.cameraZoomSlider!.value);
        this.cameraZoomValue!.textContent = v.toFixed(2) + '×';
        this.setCameraZoom!(v);
      });
    }
    
    this.debugVisualsCheckbox.addEventListener('change', () => {
      this.toggleDebugVisuals();
    });
    
    this.consoleCheckbox.addEventListener('change', () => {
      this.toggleConsole(this.consoleCheckbox.checked);
    });

    if (this.shadowsCheckbox && this.setShadowsEnabled) {
      this.shadowsCheckbox.addEventListener('change', () => {
        this.setShadowsEnabled!(this.shadowsCheckbox!.checked);
      });
    }
    
    this.consoleClearBtn.addEventListener('click', () => {
      this.clearConsole();
    });

    this.consoleTabLogsBtn.addEventListener('click', () => {
      this.switchConsoleTab('logs');
    });

    this.consoleTabProfilerBtn.addEventListener('click', () => {
      this.switchConsoleTab('profiler');
    });
    
    this.consoleCloseBtn.addEventListener('click', () => {
      this.toggleConsole(false);
      this.consoleCheckbox.checked = false;
    });
  }
  
  private setupKeyboardListener(): void {
    window.addEventListener('keydown', (e) => {
      if (e.key === '`') {
        e.preventDefault();
        this.toggle();
      }
    });
  }
  
  private setupConsoleInterception(): void {
    // Store original console methods (may already be the early-capture wrappers —
    // that is fine, we chain on top of them)
    this.originalLog = console.log.bind(console);
    this.originalWarn = console.warn.bind(console);
    this.originalError = console.error.bind(console);
    this.originalDebug = console.debug.bind(console);
    
    // Override console.log
    console.log = (...args: any[]) => {
      this.originalLog.apply(console, args);
      this.addConsoleMessage('log', this.formatMessage(args));
    };
    
    // Override console.warn
    console.warn = (...args: any[]) => {
      this.originalWarn.apply(console, args);
      this.addConsoleMessage('warn', this.formatMessage(args));
    };
    
    // Override console.error
    console.error = (...args: any[]) => {
      this.originalError.apply(console, args);
      this.addConsoleMessage('error', this.formatMessage(args));
    };
    
    // Override console.debug
    console.debug = (...args: any[]) => {
      this.originalDebug.apply(console, args);
      this.addConsoleMessage('debug', this.formatMessage(args));
    };
  }

  // Import messages that were captured by the early error handler in main.ts
  // before DebugController was instantiated.
  private importEarlyConsoleMessages(): void {
    const early = (window as any).__earlyConsoleBuffer as Array<{ type: string; message: string; timestamp: Date }> | undefined;
    if (!early || early.length === 0) return;

    // Clear DOM content written by the early handler — DebugController will re-render
    if (this.consoleContent) {
      this.consoleContent.innerHTML = '';
    }

    for (const msg of early) {
      // Push directly so we don't trigger auto-show twice for old messages
      this.consoleMessages.push(msg);
      if (this.consoleMessages.length > this.maxConsoleMessages) {
        this.consoleMessages.shift();
      }
    }

    // If any errors were captured early, keep the overlay visible
    const hadErrors = early.some((m) => m.type === 'error');
    if (hadErrors) {
      this.toggleConsole(true);
    }

    // Clear the global buffer so we don't import again
    (window as any).__earlyConsoleBuffer = [];
  }
  
  private formatMessage(args: any[]): string {
    return args.map(arg => {
      if (typeof arg === 'object') {
        try {
          return JSON.stringify(arg, null, 2);
        } catch {
          return String(arg);
        }
      }
      return String(arg);
    }).join(' ');
  }
  
  private addConsoleMessage(type: string, message: string): void {
    const timestamp = new Date();
    this.consoleMessages.push({ type, message, timestamp });
    
    // Keep only the last N messages
    if (this.consoleMessages.length > this.maxConsoleMessages) {
      this.consoleMessages.shift();
    }
    
    // Auto-show the console overlay on errors without requiring the user to
    // enable debug mode manually — critical for diagnosing iOS launch failures.
    if (type === 'error' && this.consoleOverlay.classList.contains('hidden')) {
      this.toggleConsole(true);
    }

    // Update the console content if overlay is visible
    if (!this.consoleOverlay.classList.contains('hidden')) {
      this.updateConsoleDisplay();
    }
  }
  
  private updateConsoleDisplay(): void {
    this.consoleContent.innerHTML = this.consoleMessages.map(msg => {
      const time = msg.timestamp.toLocaleTimeString();
      return `<div class="console-line console-${msg.type}"><span class="console-time">[${time}]</span> ${msg.message}</div>`;
    }).join('');
    
    // Auto-scroll to bottom
    this.consoleContent.scrollTop = this.consoleContent.scrollHeight;
  }

  private switchConsoleTab(tab: 'logs' | 'profiler'): void {
    this.activeConsoleTab = tab;

    const isLogs = tab === 'logs';
    this.consoleTabLogsBtn.classList.toggle('active', isLogs);
    this.consoleTabProfilerBtn.classList.toggle('active', !isLogs);
    this.consoleLogsPanel.classList.toggle('hidden', !isLogs);
    this.consoleProfilerPanel.classList.toggle('hidden', isLogs);

    this.consoleTitle.textContent = isLogs ? 'Console' : 'Profiler';
    this.consoleClearBtn.style.display = isLogs ? 'inline-block' : 'none';

    if (!isLogs) {
      this.updateProfilerDisplay();
    }
  }
  
  private toggleConsole(show: boolean): void {
    if (show) {
      this.consoleOverlay.classList.remove('hidden');
      this.updateConsoleDisplay();
      this.updateProfilerDisplay();
      this.switchConsoleTab(this.activeConsoleTab);
    } else {
      this.consoleOverlay.classList.add('hidden');
    }
  }
  
  private clearConsole(): void {
    this.consoleMessages = [];
    this.consoleContent.innerHTML = '';
  }
  
  private toggle(forceState?: boolean): void {
    const isOpen = this.panel.classList.contains('open');
    const newState = forceState !== undefined ? forceState : !isOpen;
    
    if (newState) {
      this.panel.classList.add('open');
      this.syncUI();
    } else {
      this.panel.classList.remove('open');
    }
  }
  
  private syncUI(): void {
    const params = this.getLightParams();
    
    this.hemiIntensitySlider.value = params.hemiIntensity.toString();
    this.hemiIntensityValue.textContent = params.hemiIntensity.toFixed(1);
    this.hemiColorPicker.value = '#' + params.hemiSkyColor.toString(16).padStart(6, '0');
    
    this.sunIntensitySlider.value = params.sunIntensity.toString();
    this.sunIntensityValue.textContent = params.sunIntensity.toFixed(2);
    this.sunColorPicker.value = '#' + params.sunColor.toString(16).padStart(6, '0');
    
    this.exposureSlider.value = params.exposure.toString();
    this.exposureValue.textContent = params.exposure.toFixed(1);

    // Sync camera zoom if callback provided
    if (this.getCameraZoom && this.cameraZoomSlider && this.cameraZoomValue) {
      const z = this.getCameraZoom();
      this.cameraZoomSlider.value = z.toFixed(2);
      this.cameraZoomValue.textContent = z.toFixed(2) + '×';
    }
  }
  
  public updatePerformance(data: {
    fps: number;
    meshes: number;
    triangles: number;
    memory: number;
    frameTime: number;
    physicsTime: number;
    renderTime: number;
    updateTime?: number;
    totalFrameTime?: number;
    profilerPhases?: Record<string, number>;
  }): void {
    // Update labels
    this.perfFps.textContent = data.fps.toFixed(0);
    this.perfMeshes.textContent = data.meshes.toString();
    
    // Show exact polys if small, or M if >= 1 million
    if (data.triangles < 1000) {
      this.perfPolys.textContent = data.triangles.toString();
    } else if (data.triangles < 1000000) {
      this.perfPolys.textContent = (data.triangles / 1000).toFixed(1) + 'k';
    } else {
      this.perfPolys.textContent = (data.triangles / 1000000).toFixed(2) + 'M';
    }
    
    this.perfMemory.textContent = data.memory > 0 ? data.memory.toFixed(1) + ' MB' : 'N/A';

    // Store history
    this.frameTimes.push(data.frameTime);
    this.physicsTimes.push(data.physicsTime);
    this.renderTimes.push(data.renderTime);

    if (this.frameTimes.length > this.maxHistory) {
      this.frameTimes.shift();
      this.physicsTimes.shift();
      this.renderTimes.shift();
    }

    this.pushProfilerSample(data);

    // Draw only if performance panel is open
    if (this.perfPanel.classList.contains('open')) {
      this.drawGraphs();
    }

    if (!this.consoleOverlay.classList.contains('hidden') && this.activeConsoleTab === 'profiler') {
      this.updateProfilerDisplay();
    }
  }

  private pushProfilerSample(data: {
    frameTime: number;
    totalFrameTime?: number;
    renderTime: number;
    profilerPhases?: Record<string, number>;
  }): void {
    if (!data.profilerPhases) return;

    const totalFrameTime = data.totalFrameTime ?? data.frameTime;
    if (!Number.isFinite(totalFrameTime) || totalFrameTime <= 0) return;

    this.profilerSamples.push({
      frameTime: totalFrameTime,
      phases: {
        ...data.profilerPhases,
        render: Math.max(0, data.renderTime),
      },
    });

    if (this.profilerSamples.length > this.maxProfilerSamples) {
      this.profilerSamples.shift();
    }
  }

  private updateProfilerDisplay(): void {
    if (this.profilerSamples.length === 0) {
      this.consoleProfilerSummary.textContent = 'No samples yet. Enable debug mode and wait a second.';
      this.consoleProfilerTable.innerHTML = '';
      return;
    }

    const sampleCount = this.profilerSamples.length;
    const avgFrameTime = this.profilerSamples.reduce((sum, sample) => sum + sample.frameTime, 0) / sampleCount;
    const avgFps = avgFrameTime > 0 ? 1000 / avgFrameTime : 0;

    const aggregate = new Map<string, { total: number; current: number }>();
    for (let i = 0; i < this.profilerSamples.length; i++) {
      const sample = this.profilerSamples[i];
      const isCurrent = i === this.profilerSamples.length - 1;

      for (const [phase, value] of Object.entries(sample.phases)) {
        const row = aggregate.get(phase) ?? { total: 0, current: 0 };
        row.total += value;
        if (isCurrent) {
          row.current = value;
        }
        aggregate.set(phase, row);
      }
    }

    const rows = Array.from(aggregate.entries())
      .map(([phase, values]) => {
        const avgMs = values.total / sampleCount;
        const percent = avgFrameTime > 0 ? (avgMs / avgFrameTime) * 100 : 0;
        return {
          phase,
          label: DebugController.PHASE_LABELS[phase] ?? this.fallbackPhaseLabel(phase),
          avgMs,
          currentMs: values.current,
          percent,
        };
      })
      .filter((row) => row.avgMs > 0.01)
      .sort((a, b) => b.avgMs - a.avgMs);

    this.consoleProfilerSummary.textContent = `Avg frame ${avgFrameTime.toFixed(2)} ms (${avgFps.toFixed(1)} FPS), samples: ${sampleCount}`;

    this.consoleProfilerTable.innerHTML = `
      <table class="profiler-table">
        <thead>
          <tr>
            <th>Part</th>
            <th>Avg ms</th>
            <th>Now ms</th>
            <th>% frame</th>
          </tr>
        </thead>
        <tbody>
          ${rows.map((row) => `
            <tr>
              <td>${row.label}</td>
              <td>${row.avgMs.toFixed(2)}</td>
              <td>${row.currentMs.toFixed(2)}</td>
              <td>${row.percent.toFixed(1)}%</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  }

  private fallbackPhaseLabel(phase: string): string {
    return phase
      .replace(/([A-Z])/g, ' $1')
      .replace(/^./, (letter) => letter.toUpperCase())
      .trim();
  }

  public showPerformance(show: boolean): void {
    if (show) {
      this.perfPanel.classList.add('open');
      // Use fixed width for mobile if clientWidth is not yet available
      this.perfCanvas.width = this.perfPanel.clientWidth || 140;
      this.perfCanvas.height = 30;
    } else {
      this.perfPanel.classList.remove('open');
    }
  }

  public setDebugVisuals(enabled: boolean): void {
    if (this.debugVisualsCheckbox) {
      this.debugVisualsCheckbox.checked = enabled;
    }
  }

  private drawGraphs(): void {
    const ctx = this.perfCtx;
    const w = this.perfCanvas.width;
    const h = this.perfCanvas.height;

    ctx.clearRect(0, 0, w, h);

    // Find max value for scaling (min 16ms to show 60fps target clearly)
    const maxVal = Math.max(16.6, ...this.frameTimes);
    const scale = h / (maxVal * 1.2);

    const step = w / (this.maxHistory - 1);

    // Draw grid lines
    ctx.strokeStyle = '#333';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, h - (16.6 * scale));
    ctx.lineTo(w, h - (16.6 * scale));
    ctx.stroke();

    // Helper to draw a line
    const drawLine = (data: number[], color: string, lineWidth: number) => {
      if (data.length < 2) return;
      ctx.strokeStyle = color;
      ctx.lineWidth = lineWidth;
      ctx.beginPath();
      for (let i = 0; i < data.length; i++) {
        const x = i * step;
        const y = h - (data[i] * scale);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.stroke();
    };

    // Draw timings (back to front)
    drawLine(this.frameTimes, '#4ecdc4', 2); // Total (Teal)
    drawLine(this.physicsTimes, '#ff6b6b', 1); // Physics (Red)
    drawLine(this.renderTimes, '#f7c531', 1); // Render (Yellow)
  }

  public show(): void {
    this.toggle(true);
  }

  private resetToDefaults(): void {
    // Reset to default values
    this.setLightParams(this.defaultLightParams);
    
    // Update all sliders and value displays
    this.hemiIntensitySlider.value = this.defaultLightParams.hemiIntensity.toString();
    this.hemiIntensityValue.textContent = this.defaultLightParams.hemiIntensity.toFixed(1);
    
    this.hemiColorPicker.value = '#' + this.defaultLightParams.hemiSkyColor.toString(16).padStart(6, '0');
    
    this.hemiGroundColorPicker.value = '#' + this.defaultLightParams.hemiGroundColor.toString(16).padStart(6, '0');
    
    this.sunIntensitySlider.value = this.defaultLightParams.sunIntensity.toString();
    this.sunIntensityValue.textContent = this.defaultLightParams.sunIntensity.toFixed(2);
    
    this.sunColorPicker.value = '#' + this.defaultLightParams.sunColor.toString(16).padStart(6, '0');
    
    this.exposureSlider.value = this.defaultLightParams.exposure.toString();
    this.exposureValue.textContent = this.defaultLightParams.exposure.toFixed(1);
    
    this.envMapIntensitySlider.value = this.defaultLightParams.envMapIntensity.toString();
    this.envMapIntensityValue.textContent = this.defaultLightParams.envMapIntensity.toFixed(1);
    
    this.fogColorPicker.value = '#' + this.defaultLightParams.fogColor.toString(16).padStart(6, '0');
    
    this.fogDensitySlider.value = this.defaultLightParams.fogDensity.toString();
    this.fogDensityValue.textContent = this.defaultLightParams.fogDensity.toFixed(3);
  }

  dispose(): void {
    this.closeBtn.removeEventListener('click', () => this.toggle(false));
  }
}
</file>

<file path="ui/UIManager.ts">
import { useGameStore, UPGRADE_COSTS, getDamageUpgradeCost } from '../core/GameStore';
import { ToolType, GameEvents, onGameEvent, LootCollectedEvent, BlockType, BLOCK_PROPERTIES } from '../core/Types';
import type { VoxelData } from '../world';
import type { DroppableItem } from '../systems/DroppableItemsSystem';
import type { AvatarUISystem } from '../systems/AvatarUISystem';

export class UIManager {
  // DOM Elements
  private loadingScreen: HTMLElement;
  private loadingBar: HTMLElement;
  private loadingText: HTMLElement;
  private uiOverlay: HTMLElement;

  private goldValue: HTMLElement;
  private depthValue: HTMLElement;

  private shopBtn: HTMLElement;
  private soundToggleBtn: HTMLButtonElement;
  private shopModal: HTMLElement;
  private shopClose: HTMLElement;
  private shopItems: NodeListOf<HTMLElement>;
  private blockDebugPanel?: HTMLElement;
  private itemDebugPanel?: HTMLElement;
  private fpsCounter: HTMLElement;

  // Systems
  private avatarUISystem: AvatarUISystem | null = null;

  // State
  private attackAnimTimeout: number | null = null;
  private lastRenderedSoundEnabled: boolean | null = null;

  constructor() {
    // Get all DOM elements
    this.loadingScreen = document.getElementById('loading')!;
    this.loadingBar = document.getElementById('loading-bar')!;
    this.loadingText = document.getElementById('loading-text')!;
    this.uiOverlay = document.getElementById('ui-overlay')!;

    this.goldValue = document.getElementById('gold-value')!;
    this.depthValue = document.getElementById('depth-value')!;

    this.shopBtn = document.getElementById('shop-btn')!;
    this.soundToggleBtn = document.getElementById('sound-toggle-btn') as HTMLButtonElement;
    this.shopModal = document.getElementById('shop-modal')!;
    this.shopClose = document.getElementById('shop-close')!;
    this.shopItems = document.querySelectorAll('.shop-item-btn');
    this.blockDebugPanel = document.getElementById('block-debug-panel')!;
    this.itemDebugPanel = document.getElementById('item-debug-panel')!;
    this.fpsCounter = document.getElementById('fps-counter')!;

    this.setupEventListeners();
    this.setupGameEventListeners();
  }

  private setupEventListeners(): void {
    // Shop
    this.shopBtn.addEventListener('click', () => {
      this.openShop();
    });

    this.soundToggleBtn.addEventListener('click', () => {
      useGameStore.getState().toggleSoundEnabled();
      this.updateSoundToggle();
    });

    this.shopClose.addEventListener('click', () => {
      this.closeShop();
    });

    this.shopModal.addEventListener('click', (e) => {
      if (e.target === this.shopModal) {
        this.closeShop();
      }
    });

    // Shop items
    this.shopItems.forEach((btn) => {
      btn.addEventListener('click', () => {
        const upgrade = btn.dataset.upgrade;
        this.handleUpgrade(upgrade!);
      });
    });
  }

  private setupGameEventListeners(): void {
    // Listen for loot collection
    onGameEvent<LootCollectedEvent>(GameEvents.LOOT_COLLECTED, () => {
      this.updateGold();
      this.flashGoldCounter();
    });
  }

  // Loading screen
  setLoadingProgress(progress: number, text: string): void {
    this.loadingBar.style.width = `${progress}%`;
    this.loadingText.textContent = text;
  }

  hideLoading(): void {
    this.loadingScreen.classList.add('hidden');
    this.uiOverlay.classList.remove('hidden');
  }

  // Update UI from game state
  update(fps: number = 0): void {
    const state = useGameStore.getState();

    // Update FPS counter
    if (state.showFPS) {
        this.fpsCounter.style.display = 'block';
        this.fpsCounter.textContent = `FPS: ${Math.round(fps)}`;
    } else {
        this.fpsCounter.style.display = 'none';
    }

    // Update gold
    this.goldValue.textContent = state.gold.toString();

    // Update depth
    this.depthValue.textContent = Math.floor(state.depth).toString();

    this.updateSoundToggle();
  }

  private updateGold(): void {
    const state = useGameStore.getState();
    this.goldValue.textContent = state.gold.toString();
  }

  private flashGoldCounter(): void {
    const counter = document.getElementById('gold-counter')!;
    counter.style.transform = 'scale(1.2)';
    setTimeout(() => {
      counter.style.transform = 'scale(1)';
    }, 100);
  }

  private updateSoundToggle(): void {
    const soundEnabled = useGameStore.getState().soundEnabled;
    if (soundEnabled === this.lastRenderedSoundEnabled) {
      return;
    }

    this.lastRenderedSoundEnabled = soundEnabled;
    this.soundToggleBtn.textContent = soundEnabled ? '🔊' : '🔇';
    this.soundToggleBtn.setAttribute('aria-label', soundEnabled ? 'Mute sound' : 'Unmute sound');
    this.soundToggleBtn.classList.toggle('muted', !soundEnabled);
  }

  // Attack animation
  playAttackAnimation(): void {
    if (this.avatarUISystem) {
      this.avatarUISystem.playAttackAnimation();
    }
  }

  setAvatarUISystem(system: AvatarUISystem): void {
    this.avatarUISystem = system;
  }

  // Shop
  openShop(): void {
    this.shopModal.classList.add('open');
    this.updateShopPrices();
  }

  closeShop(): void {
    this.shopModal.classList.remove('open');
  }

  private updateShopPrices(): void {
    const state = useGameStore.getState();

    this.shopItems.forEach((btn) => {
      const upgrade = btn.dataset.upgrade;
      let cost = 0;
      let disabled = false;

      switch (upgrade) {
        case 'damage':
          cost = getDamageUpgradeCost();
          break;
        case 'turbo':
          cost = UPGRADE_COSTS.TURBO_FUEL;
          break;
        case 'bot':
          cost = UPGRADE_COSTS.BOT;
          disabled = state.hasBot;
          break;
      }

      btn.textContent = disabled ? 'OWNED' : `💰 ${cost}`;
      (btn as HTMLButtonElement).disabled = state.gold < cost || disabled;
    });
  }

  private handleUpgrade(upgrade: string): void {
    const state = useGameStore.getState();
    let success = false;

    switch (upgrade) {
      case 'damage':
        success = state.upgradeDamage();
        break;
      case 'turbo':
        success = state.buyTurboFuel();
        break;
      case 'bot':
        success = state.buyBot();
        break;
    }

    if (success) {
      this.updateShopPrices();
      this.updateGold();

      // Dispatch event for game to react
      window.dispatchEvent(new CustomEvent('upgrade:purchased', { detail: { upgrade } }));
    }
  }

  // Get current tool for input handling
  getCurrentTool(): ToolType {
    return useGameStore.getState().currentTool;
  }

  // Update block debug info display
  updateBlockDebugInfo(block: VoxelData | null, chunkId?: number): void {
    if (!this.blockDebugPanel) return;

    const debugMode = useGameStore.getState().debugMode;

    if (!debugMode || !block) {
      this.blockDebugPanel.classList.remove('open');
      this.blockDebugPanel.classList.add('hidden');
      return;
    }

    this.blockDebugPanel.classList.remove('hidden');
    this.blockDebugPanel.classList.add('open');

    const stabilityScore = block.hasBottomNeighbor ? '∞' :
      (block.gripForce * (1 - block.wobble) * block.sideNeighborCount * 0.25).toFixed(2);

    const typeEl = document.getElementById('debug-block-type')!;
    const posEl = document.getElementById('debug-block-pos')!;
    const chunkEl = document.getElementById('debug-block-chunk')!;
    const hpEl = document.getElementById('debug-block-hp')!;
    const stabilityEl = document.getElementById('debug-block-stability')!;
    const wobbleEl = document.getElementById('debug-block-wobble')!;
    const neighborsEl = document.getElementById('debug-block-neighbors')!;
    const clusterEl = document.getElementById('debug-block-cluster')!;
    const gripEl = document.getElementById('debug-block-grip')!;
    const lockedEl = document.getElementById('debug-block-locked')!;
    const visibleEl = document.getElementById('debug-block-visible')!;
    const damageEl = document.getElementById('debug-block-damage')!;

    typeEl.textContent = BlockType[block.type];
    posEl.textContent = `(${block.x}, ${block.y}, ${block.z})`;
    chunkEl.textContent = chunkId !== undefined ? chunkId.toString() : '-';
    hpEl.textContent = `${block.hp.toFixed(0)}/${BLOCK_PROPERTIES[block.type].hp}`;
stabilityEl.textContent = stabilityScore;
wobbleEl.textContent = block.wobble.toFixed(2);
neighborsEl.textContent = `${block.sideNeighborCount} (side: ${block.hasSideNeighbors}, bottom: ${block.hasBottomNeighbor})`;
clusterEl.textContent = block.clusterId.toString();
gripEl.textContent = block.gripForce.toFixed(1);
lockedEl.textContent = block.isLocked ? 'Yes' : 'No';
visibleEl.textContent = block.isVisible ? 'Yes' : 'No';
damageEl.textContent = block.damageStage.toFixed(0);
}

  // Update item debug info display
  updateItemDebugInfo(item: DroppableItem | null): void {
    if (!this.itemDebugPanel) return;

    const debugMode = useGameStore.getState().debugMode;

    if (!debugMode || !item) {
      this.itemDebugPanel.classList.remove('open');
      this.itemDebugPanel.classList.add('hidden');
      return;
    }

    this.itemDebugPanel.classList.remove('hidden');
    this.itemDebugPanel.classList.add('open');

    const typeEl = document.getElementById('debug-item-type')!;
    const posEl = document.getElementById('debug-item-pos')!;
    const valueEl = document.getElementById('debug-item-value')!;
    const velocityEl = document.getElementById('debug-item-velocity')!;
    const sleepingEl = document.getElementById('debug-item-sleeping')!;
    const modelEl = document.getElementById('debug-item-model')!;

    let velocity = 0;
    let isSleeping = false;

    if (item.physicsBody) {
      const rigidBody = item.physicsBody.rigidBody;
      const linvel = rigidBody.linvel();
      velocity = Math.sqrt(linvel.x ** 2 + linvel.y ** 2 + linvel.z ** 2);
      isSleeping = rigidBody.isSleeping();
    }

    typeEl.textContent = item.type;
    posEl.textContent = `(${item.sprite.position.x.toFixed(2)}, ${item.sprite.position.y.toFixed(2)}, ${item.sprite.position.z.toFixed(2)})`;
    valueEl.textContent = item.value.toString();
    velocityEl.textContent = velocity.toFixed(3);
    sleepingEl.textContent = isSleeping ? 'sleeping' : 'moving';
    modelEl.textContent = item.collected ? 'collected' : `scale: ${item.sprite.scale.x.toFixed(2)}`;
  }

  // Update resource debug info display
  updateResourceDebugInfo(resource: DroppableItem | null): void {
    this.updateItemDebugInfo(resource);
  }

  // Dispose
  dispose(): void {
    if (this.attackAnimTimeout) {
      clearTimeout(this.attackAnimTimeout);
    }
  }
}
